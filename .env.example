# =========================
# Hornelore 1.0 — Horne Family Archive
# Based on Lorevox 9.0 stack
# =========================

# =========================
# PRIMARY GPU MODEL (Hornelore-owned copy — WO-11 separation boundary)
# =========================
# WO-11: Hornelore now has its own model copy at /mnt/c/models/hornelore.
# This lets Hornelore swap models (Hermes, Qwen, etc.) without affecting
# the Lorevox copy at /mnt/c/Llama-3.1-8B. The HF cache (HF_HOME /
# TRANSFORMERS_CACHE) is also Hornelore-local so transformer downloads
# don't cross-contaminate.
MODEL_ID=meta-llama/Meta-Llama-3.1-8B-Instruct
QUANT=4bit
MAX_NEW_TOKENS=3072
MAX_CONTEXT_WINDOW=8192
TEMPERATURE=0.3

MODEL_PATH=/mnt/c/models/hornelore/Meta-Llama-3.1-8B-Instruct
MODEL_DIR=/mnt/c/models/hornelore
HF_HOME=/mnt/c/models/hornelore/hf_home
TRANSFORMERS_CACHE=/mnt/c/models/hornelore/hf_home

# =========================
# CUDA / Torch Tuning
# =========================
TORCH_DTYPE=bfloat16
DEVICE_MAP=cuda:0
PYTORCH_ALLOC_CONF=max_split_size_mb:128
LOAD_IN_4BIT=1
ATTN_IMPL=sdpa

# =========================
# Hugging Face Auth
# =========================
HUGGINGFACE_HUB_TOKEN=hf_REPLACE_WITH_YOUR_TOKEN
HF_HUB_ENABLE_HF_TRANSFER=1
HF_HUB_ENABLE_XET=1
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# =========================
# RAG + Embeddings
# =========================
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_DEVICE=cpu
MEMORY_K=6
FAISS_PATH=code/rag/index

# =========================
# HORNELORE DATA — SEPARATE from Lorevox
# =========================
DATA_DIR=/mnt/c/hornelore_data
AUTHORS_DIR=/mnt/c/hornelore_data/authors
KNOWLEDGE_DIR=/mnt/c/hornelore_data
DB_NAME=hornelore.sqlite3
DB_PATH=/mnt/c/hornelore_data/hornelore.sqlite3
UPLOADS_DIR=/mnt/c/hornelore_data/uploads
MEDIA_DIR=/mnt/c/hornelore_data/media
MAX_UPLOAD_MB=50

# =========================
# Coqui TTS (WO-11: Hornelore-local cache to survive lorevox retirement)
# =========================
TTS_DEVICE=cpu
TTS_GPU=0
TTS_MODEL=tts_models/en/vctk/vits
TTS_SPEAKER_LORI=p335
TTS_HOME=/mnt/c/hornelore_data/tts_cache

# =========================
# Server + CORS
# =========================
HOST=127.0.0.1
PORT=8000
TTS_PORT=8001
CORS_ORIGINS=*

# =========================
# Interview Driver
# =========================
AUTO_NEXT=1
AUTO_NEXT_STRATEGY=plan_order

# =========================
# STT
# =========================
STT_MODEL=large-v3
STT_GPU=1

# =========================
# Feature Flags
# =========================
LV_ENABLE_SAFETY=1
LV_ENABLE_AFFECT=1
LV_ENABLE_CAMERA=1
LV_ENABLE_TTS=1
# WO-13: Family Truth v2 pipeline flags
# facts_write — freezes legacy /api/facts/add (returns 410 Gone)
HORNELORE_TRUTH_V2=1
# profile — GET /api/profiles/{id} reads from family_truth_promoted
HORNELORE_TRUTH_V2_PROFILE=1

# =========================
# Logging
# =========================
HEARTBEAT_INTERVAL=300
LOG_RETENTION_DAYS=30
LOG_LEVEL=INFO
APP_ENV=local

# =========================
# Dev / Debug
# =========================
LV_DEV_MODE=0
LV_SHOW_DEBUG_PILLS=0

# UI static files (WO-11: standalone repo path)
UI_DIR=/mnt/c/Users/chris/hornelore/ui
