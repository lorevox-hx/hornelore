# =========================
# Hornelore 1.0 — Horne Family Archive
# Based on Lorevox 9.0 stack
# =========================

# =========================
# PRIMARY GPU MODEL (Hornelore-owned copy — WO-11 separation boundary)
# =========================
# WO-11: Hornelore now has its own model copy at /mnt/c/models/hornelore.
# This lets Hornelore swap models (Hermes, Qwen, etc.) without affecting
# the Lorevox copy at /mnt/c/Llama-3.1-8B. The HF cache (HF_HOME /
# TRANSFORMERS_CACHE) is also Hornelore-local so transformer downloads
# don't cross-contaminate.
MODEL_ID=meta-llama/Meta-Llama-3.1-8B-Instruct
QUANT=4bit
MAX_NEW_TOKENS=3072
MAX_CONTEXT_WINDOW=8192
TEMPERATURE=0.3

# =========================
# WO-QA tunables — live chat defaults (cfg_expressive winner from WO-QA-02)
# =========================
# Production defaults selected from the WO-QA-02 quality harness — see
# docs/wo-qa/WO-QA-02-RESULTS.md for the rationale. cfg_expressive ranked
# #1 across both narrator styles in two consecutive matrix runs (suppression
# noise floor ±4). UI also sends temperature=0.7 + max_new_tokens=512
# explicitly per request (app.js); env values back-stop those.
#
# MAX_NEW_TOKENS_CHAT        — floor when UI omits params.max_new_tokens
# MAX_NEW_TOKENS_CHAT_HARD   — absolute server-side ceiling for chat WS
# REPETITION_PENALTY_DEFAULT — applied when UI omits params.repetition_penalty;
#                               WO-QA harness sweeps this per-request via params
MAX_NEW_TOKENS_CHAT=512
MAX_NEW_TOKENS_CHAT_HARD=2048
REPETITION_PENALTY_DEFAULT=1.05

# =========================
# Extraction tuning — /api/extract-fields LLM call parameters
# =========================
# EXTRACTION_TEMP         — generation temperature for extraction (default 0.15)
# EXTRACTION_TOP_P        — nucleus sampling for extraction (default 0.9)
# MAX_NEW_TOKENS_EXTRACT  — token cap for simple single-fact answers (default 128)
# MAX_NEW_TOKENS_EXTRACT_COMPOUND — token cap for compound multi-entity answers (default 384)
EXTRACTION_TEMP=0.15
EXTRACTION_TOP_P=0.9
MAX_NEW_TOKENS_EXTRACT=128
MAX_NEW_TOKENS_EXTRACT_COMPOUND=384

MODEL_PATH=/mnt/c/models/hornelore/Meta-Llama-3.1-8B-Instruct
MODEL_DIR=/mnt/c/models/hornelore
HF_HOME=/mnt/c/models/hornelore/hf_home
TRANSFORMERS_CACHE=/mnt/c/models/hornelore/hf_home

# =========================
# CUDA / Torch Tuning
# =========================
TORCH_DTYPE=bfloat16
DEVICE_MAP=cuda:0
PYTORCH_ALLOC_CONF=max_split_size_mb:128
LOAD_IN_4BIT=1
ATTN_IMPL=sdpa

# =========================
# Hugging Face Auth
# =========================
HUGGINGFACE_HUB_TOKEN=hf_REPLACE_WITH_YOUR_TOKEN
HF_HUB_ENABLE_HF_TRANSFER=1
HF_HUB_ENABLE_XET=1
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# =========================
# RAG + Embeddings
# =========================
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_DEVICE=cpu
MEMORY_K=6
FAISS_PATH=code/rag/index

# =========================
# HORNELORE DATA — SEPARATE from Lorevox
# =========================
DATA_DIR=/mnt/c/hornelore_data
AUTHORS_DIR=/mnt/c/hornelore_data/authors
KNOWLEDGE_DIR=/mnt/c/hornelore_data
DB_NAME=hornelore.sqlite3
DB_PATH=/mnt/c/hornelore_data/hornelore.sqlite3
UPLOADS_DIR=/mnt/c/hornelore_data/uploads
MEDIA_DIR=/mnt/c/hornelore_data/media
MAX_UPLOAD_MB=50

# =========================
# Coqui TTS (WO-11: Hornelore-local cache to survive lorevox retirement)
# =========================
TTS_DEVICE=cpu
TTS_GPU=0
TTS_MODEL=tts_models/en/vctk/vits
TTS_SPEAKER_LORI=p335
TTS_HOME=/mnt/c/hornelore_data/tts_cache

# WO-ML-TTS-EN-ES-01 — pluggable TTS engine selector.
#   coqui  (default) → existing English-only Coqui VCTK VITS, byte-stable
#                       with pre-WO behavior. No new pip deps required.
#   kokoro            → Apache 2.0 multilingual (en + es + fr/it/pt/ja/zh/hi).
#                       Requires: pip install kokoro phonemizer
#                                 + apt-get install espeak-ng (for non-EN)
# Set to "kokoro" only after pip install completes (see scripts/setup/
# install_kokoro.sh). Leaving unset / "coqui" preserves existing behavior.
LORI_TTS_ENGINE=coqui

# Kokoro voice defaults — engine-specific keys, ignored when LORI_TTS_ENGINE
# is "coqui". Voice list at https://github.com/hexgrad/kokoro
#   English (lang_code='a'): af_heart, af_bella, af_nova, af_sarah,
#                             am_michael, am_eric, am_liam, am_onyx
#   Spanish (lang_code='e'): ef_dora, em_alex, em_santa
LORI_TTS_KOKORO_VOICE_EN=af_heart
LORI_TTS_KOKORO_VOICE_ES=ef_dora

# =========================
# Server + CORS
# =========================
HOST=127.0.0.1
PORT=8000
TTS_PORT=8001
CORS_ORIGINS=*

# =========================
# Interview Driver
# =========================
AUTO_NEXT=1
AUTO_NEXT_STRATEGY=plan_order

# =========================
# STT
# =========================
STT_MODEL=large-v3
STT_GPU=1

# =========================
# Feature Flags
# =========================
# LV_ENABLE_SAFETY — WO-LORI-SAFETY-INTEGRATION-01 Phase 7 kill-switch.
# Default 1 (safety enabled). Setting to 0 DISABLES the entire chat-path
# safety pipeline: pattern scan, LLM second-layer, segment_flag
# persistence, softened-mode, operator notification, and the discipline
# exemption.
#
# DEVELOPER USE ONLY. Use cases:
#   - Automated chat-path tests where deterministic safety routing
#     would mask normal-turn behavior under inspection
#   - Eyeballing a clean composer / extractor surface without safety
#     interjections
#
# NEVER set to 0 in a real narrator session. The ACUTE SAFETY RULE in
# the system prompt still fires unconditionally, but operator
# visibility, segment_flag persistence, and softened-mode all DISAPPEAR.
# When LV_ENABLE_SAFETY=0, every turn emits a [chat_ws][safety][KILL-SWITCH]
# WARNING in api.log so the disabled state is visible to operators
# inspecting logs mid-session.
LV_ENABLE_SAFETY=1
# LV_ENABLE_AFFECT / LV_ENABLE_CAMERA / LV_ENABLE_TTS — vestigial flags
# from earlier prototypes; not currently read by server code. Listed
# here so .env.example stays in sync with .env. Wire-in-or-delete is
# tracked separately (post-parent-session).
LV_ENABLE_AFFECT=1
LV_ENABLE_CAMERA=1
LV_ENABLE_TTS=1
# WO-13: Family Truth v2 pipeline flags
# facts_write — freezes legacy /api/facts/add (returns 410 Gone)
HORNELORE_TRUTH_V2=1
# profile — GET /api/profiles/{id} reads from family_truth_promoted
HORNELORE_TRUTH_V2_PROFILE=1

# WO-EX-VALIDATE-01 — age-math plausibility gate in /api/extract-fields.
# When 1, extractor drops items flagged 'impossible' (e.g., first_job at
# age 4, Medicare before 65) and annotates others with plausibility_flag.
# Default 0 — enable only after live validation verifies no false positives.
HORNELORE_AGE_VALIDATOR=0

# WO-LIFE-SPINE-05 — phase-aware question composer.
# When 1, interview router picks questions from data/prompts/question_bank.json
# based on narrator current age vs phase age ranges. Falls back to sequential
# DB ordering when narrator has no DOB or bank is unavailable.
# Default 0 — keep tomorrow's test on the known-good sequential flow.
HORNELORE_PHASE_AWARE_QUESTIONS=0

# WO-EX-TWOPASS-01 — two-pass extraction pipeline.
# When 1, /api/extract-fields uses span-tagger (pass 1) + field-classifier
# (pass 2) instead of single-pass LLM extraction. Falls back to single-pass
# on pass 1 failure. Default 0 — enable after A/B eval confirms improvement.
HORNELORE_TWOPASS_EXTRACT=0

# WO-LORI-PHOTO-SHARED-01 — Phase 1 photo authority layer.
# When 1, the /api/photos router is live (curator upload, narrator show-next,
# photo_memory capture, session-end finalization). When 0, every endpoint
# under /api/photos returns 404 so the surface is invisible to the UI.
# Phase 2 flags HORNELORE_PHOTO_INTAKE and HORNELORE_PHOTO_ELICIT only take
# effect when this flag is also on.
HORNELORE_PHOTO_ENABLED=0

# =========================
# WO-LORI-SAFETY-INTEGRATION-01 Phase 3 — operator notification surface
# =========================
# Backend gate for /api/operator/safety-events* endpoints (Bug Panel
# banner + between-session digest). Default 0 → every endpoint returns
# 404 so it doesn't advertise itself. Set to 1 once the Bug Panel UI
# (Phase 3b) is wired and you're ready for the operator surface.
# Note: this is single-operator local-first software — when Lorevox
# adopts these endpoints they'll be fronted with operator-tab auth.
HORNELORE_OPERATOR_SAFETY_EVENTS=0

# =========================
# DB inspector (dev-only)
# =========================
# Backend gate for /db/tables and /db/table/{name} endpoints. Default 0 →
# every endpoint returns 404 so the route doesn't advertise itself. Set
# to 1 only when actively debugging schema / row content. Sensitive
# columns (content, profile_json, value, turn_excerpt, matched_phrase,
# etc.) are still redacted unless LV_DEV_MODE=1 is also set.
# Turn OFF for parent sessions.
HORNELORE_DB_INSPECTOR=0

# =========================
# WO-BUG-PANEL-EVAL-HARNESS-01 Phase 1 — read-only eval cockpit
# =========================
# Backend gate for /api/operator/eval-harness/* endpoints (Bug Panel
# Eval Harness section). Default 0 → every endpoint returns 404 so it
# doesn't advertise itself. Set to 1 once the Bug Panel UI is live and
# you want the Extractor / Lori Behavior / Safety / Story Surface
# status cards visible. Read-only in Phase 1 — no run buttons.
HORNELORE_OPERATOR_EVAL_HARNESS=0

# =========================
# WO-OPERATOR-RESOURCE-DASHBOARD-01 — live stack/resource cockpit
# =========================
# Backend gate for /api/operator/stack-dashboard/* endpoints (Bug Panel
# Stack Dashboard section). Default 0 → every endpoint returns 404 so
# the surface doesn't advertise itself. Set to 1 to enable the
# car-dashboard-style live gauges for CPU, RAM, GPU, services, capture
# state, archive writes, and eval progress. Read-only.
#
# Optional threshold overrides (all default-good; override only if your
# box runs hot or you want different amber/red lines):
#   DASH_CPU_AMBER (default 80)        DASH_CPU_RED (default 95)
#   DASH_RAM_AMBER (default 80)        DASH_RAM_RED (default 95)
#   DASH_DISK_AMBER (default 85)       DASH_DISK_RED (default 95)
#   DASH_VRAM_FREE_AMBER_MB (default 2048)  DASH_VRAM_FREE_RED_MB (default 512)
#   DASH_GPU_TEMP_AMBER (default 82)        DASH_GPU_TEMP_RED (default 92)
#   DASH_SVC_LATENCY_AMBER_MS (default 2000) DASH_SVC_LATENCY_RED_MS (default 10000)
#   DASH_UI_HEARTBEAT_TTL_SEC (default 30 — past this, capture cards go unknown)
#   DASH_ARCHIVE_STALE_AMBER_SEC (default 60)  DASH_ARCHIVE_STALE_RED_SEC (default 300)
#   DASH_EVAL_STALE_AMBER_SEC (default 30)     DASH_EVAL_STALE_RED_SEC (default 120)
HORNELORE_OPERATOR_STACK_DASHBOARD=0

# WO-OPS-STRESS-TELEMETRY-KV-01 — KV/VRAM cleanup endpoint.
# When 1 (AND HORNELORE_OPERATOR_STACK_DASHBOARD=1), exposes
# POST /api/operator/stack-dashboard/clear-kv which runs
# torch.cuda.empty_cache() + gc.collect() + torch.cuda.ipc_collect()
# and returns before/after VRAM stats. Used by the rehearsal harness's
# --clear-kv-between-voices flag during multi-voice stress runs to
# release accumulated KV-cache pressure between narrators.
# Two gates because clear-kv mutates runtime state (vs read-only
# summary/history) — opt-in only. Default-off returns 404 so the
# endpoint doesn't advertise itself.
HORNELORE_OPERATOR_CLEAR_KV=0

# =========================
# WO-LORI-STORY-CAPTURE-01 — story preservation lane
# =========================
# Master switch for the story preservation path (Path 1 in the WO).
# Default 0 → preservation is INERT (chat_ws does not call into the
# preservation service even if the table exists). Set to 1 to enable
# Lori's "remember this story" behavior in live sessions.
#
# Phase 1A note: setting this to 1 has NO effect until Phase 1A
# Commit 3b lands the chat_ws integration. The flag is reserved here
# so .env doesn't need to change again when 3b lands.
HORNELORE_STORY_CAPTURE=0

# Story-trigger thresholds. The classifier (services/story_trigger.py)
# fires "full_threshold" when ALL three of (duration ≥ MIN_DURATION_SEC,
# words ≥ MIN_WORDS, scene_anchor_count ≥ 1) are met. It fires
# "borderline_scene_anchor" when scene_anchor_count ≥ MIN_BORDERLINE
# (high anchor density rescues short turns — Janice's actual
# mastoidectomy story is below the duration/word floor but rich in
# place + relative-time + person-relation references).
#
# Defaults match WO-LORI-STORY-CAPTURE-01_Spec.md §3.3. Tune if a
# narrator runs systematically below or above the trigger floor.
STORY_TRIGGER_MIN_DURATION_SEC=30
STORY_TRIGGER_MIN_WORDS=60
STORY_TRIGGER_BORDERLINE_ANCHOR_COUNT=3

# rich_short_narrative trigger path (added 2026-05-09). Catches the
# compact emotive turns common in Spanish elder-narrator speech where
# content is rich but word/duration counts fall below full_threshold
# AND only 2 of 3 anchor axes fire (so borderline's 3-axis floor
# misses them too). Real motivating example: María's first turn —
# "Hola Lori, me llamo María. Cuando mi abuela hablaba de Perú, yo
# escuchaba su voz y me sentía cerca de ella." (21 words, ~15s,
# place + person anchors). Requires PLACE + (PERSON or TIME) AND
# words ≥ MIN_WORDS AND duration ≥ MIN_DURATION_SEC. The dual-anchor
# floor distinguishes a real memory from a place mention.
STORY_TRIGGER_RICH_SHORT_MIN_WORDS=15
STORY_TRIGGER_RICH_SHORT_MIN_DURATION_SEC=10

# WO-LORI-STORY-CAPTURE-01 Phase 1B — minimal operator review surface.
# When 1, exposes GET /api/operator/story-candidates so the Bug Panel
# can render an unreviewed-candidates list. Default-off so the route
# doesn't advertise itself to outside probes (404 when off). Phase 1B
# is read-only; promote/refine/discard actions arrive in Phase 3.
HORNELORE_OPERATOR_STORY_REVIEW=0

# WO-EX-UTTERANCE-FRAME-01 Phase 0-2 — observability log only.
# When 1, chat_ws emits a single [utterance-frame] log line per
# narrator turn carrying the Story Clause Map summary (subject class,
# event class, place, negation/uncertainty flags, candidate field
# hints). Default-off because this is a Phase 0-2 instrumentation
# flag, not a feature flag — the frame produces NO behavior change
# regardless of this setting. Consumers (extractor binding, Lori
# echo grounding, validator) wire in later phases under their own
# flags.
#
# Pure observability:
#   - Frame is built from narrator text only (no DB, no LLM, no IO).
#   - Frame is NOT consumed by extractor / Lori / safety / UI.
#   - Frame failure is non-fatal — turn always continues.
#   - System directives ([SYSTEM_QF: ...]) are skipped (same rule as
#     story-trigger logging).
#
# Use case: turn this on for a session you want to survey, then grep
# api.log for `[utterance-frame]` to inspect what the parser produces
# on real narrator-shaped text.
HORNELORE_UTTERANCE_FRAME_LOG=0

# WO-NARRATIVE-CUE-LIBRARY-01 Phase 4 — observability log only.
# When 1, chat_ws emits a single [lori-cue] log line per narrator turn
# carrying the top cue type detected from the v1 cue library
# (parent_character / elder_keeper / journey_arrival / home_place /
# work_survival / hearth_food / object_keepsake / language_name /
# identity_between / hard_times / hidden_custom / legacy_wisdom),
# its risk level, score, and which trigger terms fired. Default-off
# because this is a Phase 4 instrumentation flag, not a feature flag —
# the cue library produces NO behavior change to live narrator
# sessions regardless of this setting. The cue library is a LISTENER
# AID per the WO spec; truth flows only through the existing
# extractor → Review Queue → promoted History pipeline.
#
# Pure observability:
#   - Cue is detected from narrator text only (no DB, no LLM, no IO).
#   - Cue is NOT consumed by Lori / extractor / safety / UI.
#   - Cue failure is non-fatal — turn always continues.
#   - System directives ([SYSTEM_QF: ...]) are skipped (same rule as
#     story-trigger and utterance-frame logging).
#
# Use case: turn this on for a session you want to survey, then grep
# api.log for `[lori-cue]` to inspect which cue types fire on real
# narrator-shaped text. Feed observations back into the library JSON
# (data/lori/narrative_cue_library.v1.seed.json) via the eval harness
# (scripts/run_narrative_cue_eval.py). Phase 5+ wires the cue into
# Lori's response composer behind a separate flag.
HORNELORE_LORI_CUE_LOG=0

# WO-LORI-SESSION-AWARENESS-01 Phase 1c-wire — Peek-at-Memoir live wiring.
# When 1, chat_ws's memory_echo branch threads promoted_truth +
# safety-filtered transcript into runtime71["peek_data"]. The composer
# (compose_memory_echo) renders a new "From our records" section
# surfacing facts that the family_truth promotion pipeline has approved.
# Default-OFF because surfacing promoted truth is a real narrator-facing
# behavior change that should be Chris-validated on the parent-session
# readiness harness before flipping live.
#
# Pure read path:
#   - Reads from family_truth_promoted (db.ft_list_promoted)
#   - Reads from session transcript (archive.read_transcript)
#   - Pipes transcript through safety.filter_safety_flagged_turns
#     (Phase 5c) so distress turns NEVER appear in memory_echo
#   - Failure on any underlying read is captured in errors[] and
#     logged; turn always continues
#
# When this flag is on, every memory_echo turn ("what do you know
# about me?") includes promoted facts. When off, runtime71 has no
# peek_data key and the composer skips the new section entirely
# (byte-stable with pre-Phase-1c behavior).
HORNELORE_PEEK_AT_MEMOIR_LIVE=0

# WO-LORI-SAFETY-INTEGRATION-01 Phase 2 — LLM second-layer safety classifier.
# When 1, chat_ws.py invokes the LLM-side safety classifier
# (server/code/api/safety_classifier.py) in parallel with the existing
# deterministic pattern detector (safety.py / scan_answer). Catches
# indirect ideation language that regex patterns can't safely match
# by design — examples: "everyone would be better off without me",
# "I just don't see the point in any of this anymore", "I want it
# to be over". Distinguishes past-tense reflective from present-tense
# distressed/ideation/acute.
#
# Composition rule (locked, see WO spec):
#   - Pattern detector wins on positive detection (always)
#   - LLM classifier fills gaps — only used when pattern returns None
#   - On parse failure or LLM error, falls back to pattern (fail-OPEN)
#
# Default-off because (1) each turn adds ~1-2s LLM round-trip latency;
# (2) needs Phase 6 red-team validation before live narrator use; (3)
# pattern layer is already the safety floor and has been live since
# Phase 1 (2026-04-29).
#
# Use case: Chris flips this for a session of red-team probes, greps
# api.log for [safety_classifier] markers, and verifies the LLM-side
# layer catches indirect ideation cases the pattern layer misses
# without false-positive over-firing on normal narrative.
HORNELORE_SAFETY_LLM_LAYER=0

# BUG-LORI-SAFETY-FALSE-POSITIVE-EXTERNAL-FEAR-01 (2026-05-09) — LLM-side
# confidence floor for routing distressed/ideation classifications to
# the 988-dispatching safety pipeline. Reaction to Mary's session: the
# LLM second-layer false-positived "I am kind of scared, are you safe to
# talk to?" into distressed/ideation at ~0.5 confidence and 988'd an
# 86yo who was anxious about the AI itself. This floor blocks
# low-confidence Llama-3.1-8B chatty guesses on ambiguous narrator
# anxiety while still admitting confident ideation flags.
#
# 0.65 default — empirically: high enough to filter false-positive
# external-fear classifications, low enough that "no point getting up
# anymore" easily clears 0.65 even on a small model.
#
# Acute is exempt — the LLM saying 'acute' (explicit self-harm
# language) always routes regardless of confidence, since the cost of
# missing acute >> the cost of a false positive on acute.
#
# Pattern-side detections in safety.py are NOT affected by this floor;
# they have their own per-pattern confidence thresholds.
HORNELORE_SAFETY_LLM_CONFIDENCE_FLOOR=0.65

# WO-INTERVIEW-CLOCK-01 (2026-05-02) — narrator orientation clock place
# line. Static config string, single key. NOT browser geolocation,
# NOT IP-geolocation — both are wrong-when-wrong in alarming ways for
# an older-adult kiosk install. Empty value collapses the place line
# cleanly per WO design rule (clock still renders time + day + date).
#
# Per-narrator override available via localStorage["lvNarratorLocation"]
# (operator dev convenience). Server-side wiring of this env var into
# the UI is pending — current v1 reads window.LV_NARRATOR_LOCATION OR
# localStorage. To set a stack-wide default before that wiring lands:
#     export LOREVOX_NARRATOR_LOCATION="Las Vegas, New Mexico"
#   in the shell that runs start_all.sh, then manually mirror it via
#     localStorage.setItem("lvNarratorLocation", "Las Vegas, New Mexico")
#   in the narrator browser. Phase 2 will inject this at server-render
#   time so the manual mirror step is no longer needed.
LOREVOX_NARRATOR_LOCATION=

# WO-LORI-HARNESS-01 — operator harness HTTP shim over /api/chat/ws.
# When 1, exposes POST /api/operator/harness/interview-turn so the
# golfball harness (and other ops scripts) can run synchronous chat
# turns via a stable HTTP contract instead of speaking the WS protocol.
# Default-off so the route doesn't advertise itself to outside probes
# (404 when off). The endpoint internally opens a WebSocket to its own
# /api/chat/ws — server eats its own dogfood — so the contract stays
# accurate to chat_ws.py without code duplication.
HORNELORE_OPERATOR_HARNESS=0

# Soft session-end pacing. At LORI_SESSION_SOFT_WARN_MIN minutes Lori
# offers a break. At LORI_SESSION_HARD_CAP_MIN minutes the session
# ends warmly (does NOT cut narrator audio mid-utterance — waits for
# the current turn to finish). Both reserved here for Phase 2 use.
LORI_SESSION_SOFT_WARN_MIN=25
LORI_SESSION_HARD_CAP_MIN=30

# =========================
# WO-LORI-QUESTION-ATOMICITY-01 / WO-LORI-REFLECTION-01
# =========================
# Layer 2 deterministic atomicity filter. When set, runs
# enforce_question_atomicity() on assistant_text after the LLM stream
# completes (post-stream, pre-`done` event). Truncates at the first
# pivot when one of the 6 illegal-structure patterns fires
# (and_pivot / or_speculation / request_plus_inquiry / choice_framing
# / hidden_second_target / dual_retrieval_axis). Default OFF for the
# first eval cycle — flip to 1 after the golfball harness shows
# atomicity_failures==0 across two consecutive runs and the master
# extractor eval shows no regression. Skips when the safety classifier
# has triggered for the turn.
HORNELORE_ATOMICITY_FILTER=0

# Layer 1 (the LORI_QUESTION_ATOMICITY directive in
# prompt_composer.py / LORI_INTERVIEW_DISCIPLINE) is always on; it
# rides on every interview-side composer regardless of this flag.

# Memory-echo validator (WO-LORI-REFLECTION-01). Validator-only — no
# mutation of assistant_text. Logs failure labels via
# [chat_ws][reflection] log marker. Operators can correlate label
# rates with prompt-composer changes. Default OFF for the first eval
# cycle.
#
# DEPRECATED 2026-05-01: superseded by HORNELORE_COMMUNICATION_CONTROL
# below. The unified wrapper composes both atomicity and reflection
# enforcement. Kept for backward compat / staged rollout.
HORNELORE_REFLECTION_VALIDATOR=0

# WO-LORI-COMMUNICATION-CONTROL-01 — unified runtime communication
# guard. Composes question_atomicity (truncate compounds) +
# lori_reflection (validate echo) and adds:
#   * Per-session-style word-count limits:
#       clear_direct=55 / warm_storytelling=90 /
#       questionnaire_first=70 / companion=80
#   * Question-count cap (≤1 per turn)
#   * Acute-safety exemption (acute SAFETY responses keep their own
#     structure; only "normal Q during safety" is flagged)
#
# Architecture grounding: Wang et al. 2025 STA — prompt engineering is
# fragile, deterministic enforcement is robust. Rappa et al. 2026 —
# Grice's maxims (Quantity / Manner / Relation / Quality) define what
# correct interview communication is. This wrapper is the runtime
# authority; LORI_INTERVIEW_DISCIPLINE in prompt_composer is Layer 1
# (always-on guidance).
#
# When ON, this wrapper runs and supersedes HORNELORE_ATOMICITY_FILTER
# / HORNELORE_REFLECTION_VALIDATOR (those flags are deprecated).
# Default OFF for the first eval cycle. Flip to 1 after one clean
# golfball harness run shows atomicity_failures=[] across Turns 02-05
# AND master extractor eval shows no regression.
HORNELORE_COMMUNICATION_CONTROL=0

# WO-LORI-REFLECTION-02 — runtime reflection shaping (Patch C).
# When ON (and HORNELORE_COMMUNICATION_CONTROL is also ON), the comm-
# control wrapper runs shape_reflection() over Lori's emitted text:
#   - Case B: no echo + anchor available → prepend "{anchor}. "
#   - Case C1: echo too long + anchor inside → trim to anchor + question
#   - Case C2: echo too long + no anchor in echo → drop echo
#   - Layer 3: softened-mode response > 30 words → truncate to first sentence
# The shaper never invents narrator content — it only re-arranges or
# trims what Lori already produced. Idempotent. Pure post-LLM.
# Spec: BUG-LORI-REFLECTION-02_Spec.md (locked principle: prompt-heavy
# reflection rules made Lori worse on Patch B; runtime shaping is the
# only path forward).
# Default OFF for the first golfball cycle. Flip to 1 after two
# consecutive golfball passes at ≥ 6/8 with the flag ON.
HORNELORE_REFLECTION_SHAPING=0

# WO-ML-01 Phase 1B (2026-05-07) — Whisper-backed STT engine
# (frontend feature flag, NOT a server env var).
#
# Lorevox's live STT today is the browser's Web Speech API, which:
#   - Sends audio to Google's servers (privacy posture mismatch).
#   - Is English-only on most browsers.
#   - Drops interim text on mic-stop (root cause of the 2026-05-07
#     "iii" name-absorption bug — narrator's full utterance was lost
#     because Web Speech only delivered the first finalized segment).
#
# When LV_USE_WHISPER_STT=1, ui/js/whisper-stt.js takes over: audio
# chunks (~1.5s slices via MediaRecorder) POST to /api/stt/transcribe
# (faster-whisper / Whisper-large-v3 backend per STT_MODEL setting
# above), each chunk emits a SpeechRecognition-shaped result event
# with detected language + confidence + duration metadata. The rest
# of the codebase (FocusCanvas mic-modal hook, isLoriSpeaking guard,
# WO-STT-LIVE-02 fragile-fact transcript-guard) works unchanged
# because the synthetic events match the SpeechRecognitionEvent shape.
#
# This is a *frontend* flag — it lives in the browser's localStorage
# (key: lv_use_whisper_stt, value "1" → on), NOT in this .env file.
# The .env entry below exists only as a documentation anchor.
#
# To enable for the current browser:
#   localStorage.setItem("lv_use_whisper_stt", "1");
#   location.reload();
#
# To disable:
#   localStorage.removeItem("lv_use_whisper_stt");
#   location.reload();
#
# Default OFF (Web Speech remains the engine) until smoke-validated.
# Spec: docs/specs/MULTILINGUAL/MULTILINGUAL-PROJECT-PLAN.md
# Phase 1A audit: docs/reports/WO-ML-01_PHASE-1A_AUDIT.md
LV_USE_WHISPER_STT=0

# WO-LORI-SOFTENED-RESPONSE-01 — post-safety softened-mode persistence.
# When ON, chat_ws.py reads get_session_softened_state(conv_id) at
# turn-start and threads it through runtime71["softened_state"] into
# compose_system_prompt. The composer injects a SOFTENED MODE
# directive for N turns (default 3) after a safety trigger. The
# communication-control wrapper sees safety_triggered=True for the
# duration and routes through its safety-exempt path (no atomicity
# rewrite + flags "normal_interview_question_during_safety" if Lori
# slips back into interview mode).
#
# Closes parent-session readiness gate #6 (post-safety recovery).
# Companion to HORNELORE_OPERATOR_SAFETY_EVENTS=1 which gates the
# Bug Panel softened-mode banner. Default OFF for first eval cycle;
# flip to 1 after one clean rerun shows Turn 07 atomicity_failures
# clean and Turn 08 still in softened mode.
HORNELORE_SOFTENED_RESPONSE=0

# =========================
# Logging
# =========================
HEARTBEAT_INTERVAL=300
LOG_RETENTION_DAYS=30
LOG_LEVEL=INFO
APP_ENV=local

# =========================
# Dev / Debug
# =========================
LV_DEV_MODE=0
LV_SHOW_DEBUG_PILLS=0

# =========================
# WO-BUG-LORI-SWITCH-FRESH-GREETING-01 Phase 2 — continuation paraphrase
# =========================
# When 1: the welcome-back opener at /api/interview/opener routes
# through compose_continuation_paraphrase() — a deterministic four-tier
# cascade that produces an era-aware greeting:
#   "Welcome back, {name}. Last time we were in your building years.
#    Would you like to continue there, or start somewhere else?"
# Frontend passes state.session.currentEra as ?last_era_id=… on the
# opener call.
# When 0 (default): bare "Welcome back, {name}. Where would you like
# to continue today?" template fires (legacy interview.py:486-489
# behavior). Tier D of the cascade matches this template byte-for-byte
# so default-off is byte-stable.
# Slice 2a (LANDED 2026-05-05) ships Tier C (era-aware) + Tier D
# (bare welcome-back fallback). Slice 2b (after WO-LORI-MEMORY-ECHO-
# ERA-STORIES-01 Phase 1c lands) adds Tier A (era + story stub +
# unfinished thread) + Tier B (era + story stub).
# Flip to 1 once a manual smoke test confirms Tier C fires correctly
# for at least Mary and Marvin.
HORNELORE_CONTINUATION_PARAPHRASE=0

# =========================
# WO-QUESTIONNAIRE-FIRST-RETIRE-LIVE-01 — UI-only flag (NOT server env)
# =========================
# Read by ui/js/session-loop.js + ui/hornelore1.0.html via:
#   localStorage["lv_qf_live_ownership"] === "1"
# Default OFF (key absent / set to "0"): questionnaire-first and
# clear_direct session styles do NOT drive live Lori interview.
# No SYSTEM_QF auto-prompts fire. Welcome-back / opener path owns
# first prompt regardless of session style. Per CLAUDE.md design
# principle 8: "If the operator seeded it, Lori knows it. If Lori
# knows it, she does not ask for it as intake."
#
# Set to "1" in browser DevTools to reactivate the legacy QF walk
# for the optional structured-intake-mode (Phase 4 of the WO;
# manually-started, deliberately-entered).
#
# Operator commands:
#   localStorage.setItem("lv_qf_live_ownership", "1")  // reactivate
#   localStorage.removeItem("lv_qf_live_ownership")    // retire (default)
#
# This is documentation-only here; the flag is NOT a server env var.

# UI static files (WO-11: standalone repo path)
UI_DIR=/mnt/c/Users/chris/hornelore/ui
