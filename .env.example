# =========================
# Hornelore 1.0 — Horne Family Archive
# Based on Lorevox 9.0 stack
# =========================

# =========================
# PRIMARY GPU MODEL (Hornelore-owned copy — WO-11 separation boundary)
# =========================
# WO-11: Hornelore now has its own model copy at /mnt/c/models/hornelore.
# This lets Hornelore swap models (Hermes, Qwen, etc.) without affecting
# the Lorevox copy at /mnt/c/Llama-3.1-8B. The HF cache (HF_HOME /
# TRANSFORMERS_CACHE) is also Hornelore-local so transformer downloads
# don't cross-contaminate.
MODEL_ID=meta-llama/Meta-Llama-3.1-8B-Instruct
QUANT=4bit
MAX_NEW_TOKENS=3072
MAX_CONTEXT_WINDOW=8192
TEMPERATURE=0.3

# =========================
# WO-QA tunables — live chat defaults (cfg_expressive winner from WO-QA-02)
# =========================
# Production defaults selected from the WO-QA-02 quality harness — see
# docs/wo-qa/WO-QA-02-RESULTS.md for the rationale. cfg_expressive ranked
# #1 across both narrator styles in two consecutive matrix runs (suppression
# noise floor ±4). UI also sends temperature=0.7 + max_new_tokens=512
# explicitly per request (app.js); env values back-stop those.
#
# MAX_NEW_TOKENS_CHAT        — floor when UI omits params.max_new_tokens
# MAX_NEW_TOKENS_CHAT_HARD   — absolute server-side ceiling for chat WS
# REPETITION_PENALTY_DEFAULT — applied when UI omits params.repetition_penalty;
#                               WO-QA harness sweeps this per-request via params
MAX_NEW_TOKENS_CHAT=512
MAX_NEW_TOKENS_CHAT_HARD=2048
REPETITION_PENALTY_DEFAULT=1.05

# =========================
# Extraction tuning — /api/extract-fields LLM call parameters
# =========================
# EXTRACTION_TEMP         — generation temperature for extraction (default 0.15)
# EXTRACTION_TOP_P        — nucleus sampling for extraction (default 0.9)
# MAX_NEW_TOKENS_EXTRACT  — token cap for simple single-fact answers (default 128)
# MAX_NEW_TOKENS_EXTRACT_COMPOUND — token cap for compound multi-entity answers (default 384)
EXTRACTION_TEMP=0.15
EXTRACTION_TOP_P=0.9
MAX_NEW_TOKENS_EXTRACT=128
MAX_NEW_TOKENS_EXTRACT_COMPOUND=384

MODEL_PATH=/mnt/c/models/hornelore/Meta-Llama-3.1-8B-Instruct
MODEL_DIR=/mnt/c/models/hornelore
HF_HOME=/mnt/c/models/hornelore/hf_home
TRANSFORMERS_CACHE=/mnt/c/models/hornelore/hf_home

# =========================
# CUDA / Torch Tuning
# =========================
TORCH_DTYPE=bfloat16
DEVICE_MAP=cuda:0
PYTORCH_ALLOC_CONF=max_split_size_mb:128
LOAD_IN_4BIT=1
ATTN_IMPL=sdpa

# =========================
# Hugging Face Auth
# =========================
HUGGINGFACE_HUB_TOKEN=hf_REPLACE_WITH_YOUR_TOKEN
HF_HUB_ENABLE_HF_TRANSFER=1
HF_HUB_ENABLE_XET=1
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# =========================
# RAG + Embeddings
# =========================
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_DEVICE=cpu
MEMORY_K=6
FAISS_PATH=code/rag/index

# =========================
# HORNELORE DATA — SEPARATE from Lorevox
# =========================
DATA_DIR=/mnt/c/hornelore_data
AUTHORS_DIR=/mnt/c/hornelore_data/authors
KNOWLEDGE_DIR=/mnt/c/hornelore_data
DB_NAME=hornelore.sqlite3
DB_PATH=/mnt/c/hornelore_data/hornelore.sqlite3
UPLOADS_DIR=/mnt/c/hornelore_data/uploads
MEDIA_DIR=/mnt/c/hornelore_data/media
MAX_UPLOAD_MB=50

# =========================
# Coqui TTS (WO-11: Hornelore-local cache to survive lorevox retirement)
# =========================
TTS_DEVICE=cpu
TTS_GPU=0
TTS_MODEL=tts_models/en/vctk/vits
TTS_SPEAKER_LORI=p335
TTS_HOME=/mnt/c/hornelore_data/tts_cache

# =========================
# Server + CORS
# =========================
HOST=127.0.0.1
PORT=8000
TTS_PORT=8001
CORS_ORIGINS=*

# =========================
# Interview Driver
# =========================
AUTO_NEXT=1
AUTO_NEXT_STRATEGY=plan_order

# =========================
# STT
# =========================
STT_MODEL=large-v3
STT_GPU=1

# =========================
# Feature Flags
# =========================
LV_ENABLE_SAFETY=1
LV_ENABLE_AFFECT=1
LV_ENABLE_CAMERA=1
LV_ENABLE_TTS=1
# WO-13: Family Truth v2 pipeline flags
# facts_write — freezes legacy /api/facts/add (returns 410 Gone)
HORNELORE_TRUTH_V2=1
# profile — GET /api/profiles/{id} reads from family_truth_promoted
HORNELORE_TRUTH_V2_PROFILE=1

# WO-EX-VALIDATE-01 — age-math plausibility gate in /api/extract-fields.
# When 1, extractor drops items flagged 'impossible' (e.g., first_job at
# age 4, Medicare before 65) and annotates others with plausibility_flag.
# Default 0 — enable only after live validation verifies no false positives.
HORNELORE_AGE_VALIDATOR=0

# WO-LIFE-SPINE-05 — phase-aware question composer.
# When 1, interview router picks questions from data/prompts/question_bank.json
# based on narrator current age vs phase age ranges. Falls back to sequential
# DB ordering when narrator has no DOB or bank is unavailable.
# Default 0 — keep tomorrow's test on the known-good sequential flow.
HORNELORE_PHASE_AWARE_QUESTIONS=0

# WO-EX-TWOPASS-01 — two-pass extraction pipeline.
# When 1, /api/extract-fields uses span-tagger (pass 1) + field-classifier
# (pass 2) instead of single-pass LLM extraction. Falls back to single-pass
# on pass 1 failure. Default 0 — enable after A/B eval confirms improvement.
HORNELORE_TWOPASS_EXTRACT=0

# =========================
# Logging
# =========================
HEARTBEAT_INTERVAL=300
LOG_RETENTION_DAYS=30
LOG_LEVEL=INFO
APP_ENV=local

# =========================
# Dev / Debug
# =========================
LV_DEV_MODE=0
LV_SHOW_DEBUG_PILLS=0

# UI static files (WO-11: standalone repo path)
UI_DIR=/mnt/c/Users/chris/hornelore/ui
