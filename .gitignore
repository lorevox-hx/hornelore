# ── Hornelore .gitignore ──────────────────────────────────────────
# Created by WO-11 (repo separation). Keep this minimal and explicit.
# If you add a new build/runtime artifact, add it here — never ignore
# source code, launchers, schemas, or config templates.

# ── Python bytecode / caches ──
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/

# ── Virtual environments (Hornelore-owned) ──
# .venv-gpu (~8 GB), .venv-tts (~7.5 GB) — rebuild from requirements
.venv/
.venv-*/
venv/
env/

# ── Runtime state (logs, pids, signal flags, ephemeral) ──
# Ignore the whole .runtime/ tree. Launcher scripts mkdir -p the
# subdirs they need (logs, pids) and drop transient signal files
# like reset_on_start. None of it should ever be tracked.
.runtime/
*.log
*.log.prev*
*.log.[0-9]*
*.pid

# ── Local IDE / editor ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Node / Playwright (UI tooling) ──
node_modules/
playwright-report/
test-results/
.playwright/

# ── Models & large binaries (never commit) ──
# Model weights live at MODEL_PATH (see .env.example)
*.safetensors
*.gguf
*.bin
*.onnx
*.pt
*.pth

# ── Database (lives outside repo at DB_PATH) ──
*.sqlite3
*.sqlite3-journal
*.sqlite3-wal
*.sqlite3-shm
*.db
*.db-journal

# ── Runtime data (memory agents, uploads, etc.) ──
server/data/db/
server/data/memory/

# ── Environment files (secrets / tokens) ──
# Never push .env — it may contain real HF tokens, API keys, etc.
# Use .env.example as the tracked template.
.env
.env.local
.env.*.local

# ── OS / tool junk ──
*.orig
*.rej
*.bak

# ── Word temp files (created while .docx is open) ──
~$*
